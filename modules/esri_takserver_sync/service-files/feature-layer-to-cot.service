[Unit]
Description=Esri-TAKServer-Sync — Feature Layer to CoT
After=network.target

[Service]
ExecStart=/usr/bin/python3 /opt/Esri-TAKServer-Sync/feature-layer-to-cot.py
WorkingDirectory=/opt/Esri-TAKServer-Sync
StandardOutput=file:/var/log/esri-takserver-sync-feature-layer-to-cot.log
StandardError=file:/var/log/esri-takserver-sync-feature-layer-to-cot.log
Restart=on-failure
RestartSec=10
User=root

[Install]
WantedBy=multi-user.target
