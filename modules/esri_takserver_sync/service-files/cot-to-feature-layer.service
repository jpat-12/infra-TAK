[Unit]
Description=Esri-TAKServer-Sync — CoT to Feature Layer
After=network.target

[Service]
ExecStart=/usr/bin/python3 /opt/Esri-TAKServer-Sync/cot-to-feature-layer.py
WorkingDirectory=/opt/Esri-TAKServer-Sync
StandardOutput=file:/var/log/esri-takserver-sync-cot-to-feature-layer.log
StandardError=file:/var/log/esri-takserver-sync-cot-to-feature-layer.log
Restart=on-failure
RestartSec=10
User=root

[Install]
WantedBy=multi-user.target
